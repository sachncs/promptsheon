# EditorConfig is awesome: https://EditorConfig.org
#
# Most editors load this file automatically and apply the rules
# without a plugin. The settings here match gofmt output (tabs,
# final newline) plus a couple of cross-language conventions
# (UTF-8, trim trailing whitespace) so .md, .yml, and .sh files
# stay consistent across the team.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab

[*.{yml,yaml,json,toml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # Markdown uses two trailing spaces for hard line breaks

[*.{bat,cmd}]
end_of_line = crlf

[Makefile]
indent_style = tab
