# CODEOWNERS
#
# Every PR that touches a line under a path listed here must be
# reviewed by the matching owner before merge. GitHub auto-loads
# this file from the repository root and surfaces the reviewer in
# the PR UI.
#
# The default owner below is the project maintainer. Path-specific
# overrides route the highest-risk areas (auth, crypto, persistence)
# to the same person so the reviewer set is small enough to be
# actionable for a single-maintainer project. As the project grows,
# add domain owners here rather than letting reviews accumulate on
# one person.

# Default fallback: catch-all owner for any path not listed.
*       @sachncs

# Security-sensitive areas: vault, auth, audit, rate limiting,
# and the CAS engine. These encode the threat model from
# docs/security.md and should never merge without an explicit
# maintainer review.
/internal/auth/                 @sachncs
/internal/vault/                @sachncs
/internal/audit/                @sachncs
/internal/ratelimit/            @sachncs
/internal/promptsheon/          @sachncs
/internal/store/                @sachncs

# Public API surface: breaking changes here ripple to every SDK
# consumer.
/internal/api/                  @sachncs
/sdk/                           @sachncs
/api/openapi.yaml               @sachncs

# Server entry point and the OpenAPI generator.
/cmd/                           @sachncs
/scripts/genopenapi/            @sachncs

# Release / harness / scheduler / subprocess paths are
# high-blast-radius: a wrong change can take the daemon down
# or lose audit records. Each gets its own owner.
# (OPS-CODEOWNERS-1)
# Note that /.github/ (line above) already covers
# /.github/workflows/ via the glob, so we don't need a
# separate line. (OPS-CODEOWNERS-2)
/internal/release/              @sachncs
/internal/harness/              @sachncs
/internal/llm/                  @sachncs
/internal/rollups/              @sachncs
/internal/scheduler/            @sachncs
/internal/subprocess/           @sachncs
/internal/supervisor/           @sachncs
/internal/webhook/              @sachncs

# Tests, docs, scripts.
/tests/                         @sachncs
/docs/                          @sachncs
/scripts/                       @sachncs

# CI, build, release. /.github/ already covers
# /.github/workflows/ via the directory glob, so the explicit
# `/.github/workflows/` line was redundant and is dropped
# (OPS-CODEOWNERS-2).
/Dockerfile                     @sachncs
/.goreleaser.yml                @sachncs
/Makefile                       @sachncs
/SECURITY.md                    @sachncs
/CONTRIBUTING.md                @sachncs

# Helm chart + deploy manifests.
/deploy/                        @sachncs
