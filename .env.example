# Promptsheon Environment Configuration
# Copy this file to .env and fill in the values. All variables are
# prefixed with PROMPTSHEON_ except for SDK examples that mirror the
# upstream provider names.

# Server
PROMPTSHEON_ADDR=:8080
PROMPTSHEON_DB_PATH=promptsheon.db
PROMPTSHEON_AUTH=true
PROMPTSHEON_LOG_LEVEL=info
PROMPTSHEON_CORS_ORIGINS=

# Vault (encryption key for provider API keys; required for per-prompt
# API key bindings). Must be a 32-byte hex string.
PROMPTSHEON_VAULT_KEY=

# Shell tool (workflow engine). Both must be set to enable the shell
# tool. PROMPTSHEON_SHELL_ALLOWLIST is a comma-separated list of
# allowed base commands. Disabled by default.
PROMPTSHEON_SHELL_ENABLED=false
PROMPTSHEON_SHELL_ALLOWLIST=

# Webhook SSRF protection. Set to true only in local development when
# you need to register webhooks to loopback or private addresses.
# PROMPTSHEON_WEBHOOK_ALLOW_PRIVATE removed (SEC-4); webhooks reject loopback and private destinations by default

# Rate Limiting (0 disables rate limiting)
PROMPTSHEON_RATE_LIMIT=100
PROMPTSHEON_RATE_BURST=50

# LLM Providers (names match internal/llm/registry.go).
# Per docs/configuration.md the production surface ships only
# Anthropic + OpenAI; the other env vars here are documented
# but the registry has no constructor wired up.
PROMPTSHEON_OPENAI_API_KEY=
PROMPTSHEON_OPENAI_BASE_URL=
PROMPTSHEON_ANTHROPIC_API_KEY=
PROMPTSHEON_ANTHROPIC_BASE_URL=
# PROMPTSHEON_OLLAMA_BASE_URL is read-only; no Ollama registry
# provider is wired up in the daemon (see docs/llm-providers.md).
PROMPTSHEON_OLLAMA_BASE_URL=http://localhost:11434
# PROMPTSHEON_NVIDIA_API_KEY / PROMPTSHEON_NVIDIA_BASE_URL are
# referenced by docs but the registry has no NVIDIA adapter.
PROMPTSHEON_NVIDIA_API_KEY=
PROMPTSHEON_NVIDIA_BASE_URL=
