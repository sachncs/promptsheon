# Promptsheon production values example.
#
# The chart ships only the SQLite backend. Vector search is provided by
# the sqlite-vec extension loaded at startup. Multi-replica and HA are
# unsupported; SQLite is single-writer. Replica count and backend
# selection are gated by values.schema.json.

replicaCount: 1

image:
  repository: registry.example.com/promptsheon/promptsheon
  tag: "0.1.0"
  pullPolicy: Always

service:
  type: ClusterIP
  port: 80

resources:
  cpuLimit: "2"
  memoryLimit: 1Gi

config:
  addr: ":8080"
  logLevel: info
  auth: "true"
  rateLimitRate: 1000
  rateLimitInterval: 60
  corsOrigins: "https://app.example.com"
  otelEndpoint: "otel-collector.observability.svc:4317"

vault:
  enabled: true
  # Production: provide a 32-byte hex key from a sealed-secret store
  # (ESO, ExternalSecrets, Vault, etc.). Do not commit a real key here.
  key: ""

persistence:
  size: 50Gi
  accessMode: ReadWriteOnce
  storageClassName: gp3

serviceMonitor:
  enabled: true

insecureLoopback: false
