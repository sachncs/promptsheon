{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sachncs/promptsheon/helm/values.schema.json",
  "title": "Promptsheon Helm values",
  "description": "Schema that rejects configurations the daemon cannot honour. Keep this list small and explicit; the schema is the install-time safety net.",
  "type": "object",
  "additionalProperties": true,
  "required": ["replicaCount"],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "description": "Up to 3 replicas are supported when the SQLite WAL writer-leader-election layer is enabled. Single-replica is the default; multi-replica requires a writable PVC per pod. The Postgres backend was removed."
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dbBackend": {
          "type": "string",
          "enum": ["sqlite"],
          "description": "Only sqlite is supported; the postgres backend was removed in favour of sqlite-vec."
        },
        "auth": {
          "type": "string",
          "enum": ["true", "false"],
          "description": "Must be true unless insecureLoopback=true."
        },
        "logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"]
        }
      }
    },
    "insecureLoopback": {
      "type": "boolean"
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "minReplicas": {"type": "integer", "minimum": 1, "maximum": 10},
        "maxReplicas": {"type": "integer", "minimum": 1, "maximum": 10},
        "targetCPUUtilizationPercentage": {"type": "integer", "minimum": 10, "maximum": 100},
        "targetMemoryUtilizationPercentage": {"type": "integer", "minimum": 10, "maximum": 100}
      }
    },
    "leaderElection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "ttlSeconds": {"type": "integer", "minimum": 1, "maximum": 600}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "insecureLoopback": { "const": true } },
        "required": ["insecureLoopback"]
      },
      "then": {
        "properties": { "config": { "properties": { "auth": { "const": "false" } } } }
      }
    },
    {
      "if": {
        "properties": { "config": { "properties": { "auth": { "const": "false" } } } }
      },
      "then": {
        "required": ["insecureLoopback"],
        "properties": { "insecureLoopback": { "const": true } }
      }
    },
    {
      "if": {
        "properties": { "autoscaling": { "properties": { "enabled": { "const": true } } } }
      },
      "then": {
        "required": ["leaderElection"],
        "properties": { "leaderElection": { "properties": { "enabled": { "const": true } } } }
      }
    }
  ]
}
