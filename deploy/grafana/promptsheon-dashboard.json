{
  "title": "Promptsheon",
  "uid": "promptsheon-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "tags": ["promptsheon", "observability"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"}
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(promptsheon_http_requests_total, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Requests / sec",
      "id": 1,
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "sum(rate(promptsheon_http_requests_total{instance=~\"$instance\"}[1m]))"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "stat",
      "title": "Error rate",
      "id": 2,
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "100 * sum(rate(promptsheon_http_errors_total{instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(promptsheon_http_requests_total{instance=~\"$instance\"}[5m])), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Audit drops",
      "id": 3,
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "sum(promptsheon_audit_dropped_total{instance=~\"$instance\"})"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "stat",
      "title": "Trace drops",
      "id": 4,
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "sum(promptsheon_trace_dropped_total{instance=~\"$instance\"})"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "timeseries",
      "title": "HTTP latency (p50 / p95 / p99)",
      "id": 5,
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(promptsheon_http_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(promptsheon_http_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(promptsheon_http_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "LLM latency p95 + calls/sec",
      "id": 6,
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(promptsheon_llm_latency_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "llm p95"
        },
        {
          "expr": "sum(rate(promptsheon_llm_calls_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "llm calls/s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "LLM cost ($/hr)",
      "id": 7,
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(promptsheon_llm_cost_usd_total{instance=~\"$instance\"}[1h])) * 3600",
          "legendFormat": "cost usd / hr"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "USD"}}
    },
    {
      "type": "timeseries",
      "title": "Audit queue latency",
      "id": 8,
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(promptsheon_audit_queue_latency_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(promptsheon_audit_queue_latency_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "Workflow runs (total + active)",
      "id": 9,
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(promptsheon_workflow_runs_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "runs/s"
        },
        {
          "expr": "sum(promptsheon_workflow_active{instance=~\"$instance\"})",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "timeseries",
      "title": "Harness eval success rate",
      "id": 10,
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "100 * sum(rate(promptsheon_eval_cases_total{instance=~\"$instance\",result=\"pass\"}[1h])) / clamp_min(sum(rate(promptsheon_eval_cases_total{instance=~\"$instance\"}[1h])), 1)",
          "legendFormat": "pass %"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    }
  ]
}
